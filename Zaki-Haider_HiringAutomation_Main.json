    {
      "parameters": {
        "jsCode": "// Loop through all incoming items from the workflow\nreturn $input.all().map(item => {\n  const url = item.json.resumeUrl || \"\";\n  let fileId = \"\";\n\n  // Regular expression to match typical Google Drive ID formats (/d/ID or id=ID)\n  const match = url.match(/\\/d\\/([a-zA-Z0-9-_]+)/) || url.match(/[?&]id=([a-zA-Z0-9-_]+)/);\n\n  if (match && match[1]) {\n    fileId = match[1];\n  } else {\n    // If it doesn't match a URL structure, assume the string might already be a raw ID\n    fileId = url.trim();\n  }\n\n  // Return the original data along with our newly extracted ID\n  return {\n    json: {\n      ...item.json,\n      extractedFileId: fileId\n    },\n    // Preserve any binary data (like the resume file itself) if present\n    binary: item.binary \n  };\n});"
      },
