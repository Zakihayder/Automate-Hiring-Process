    {
      "parameters": {
        "jsCode": "// 1. Path updated to match the exact structure shown in image_5a983d.png\n// 1. Target the exact text array out of your custom LLM payload format\nconst aiResponse = $input.item.json.output?.[0]?.content?.[0]?.text || $input.item.json.text || \"\";\n\n// 2. FIX: Point to 'Loop Over Items' node without using .first(), maintaining loop sequence\nconst prevData = $('Loop Over Items').item.json;\n// Parse the JSON from AI response\nlet aiResult;\ntry {\n  // Extract JSON string from the response blocks (handling markdown ```json wrappers)\n  const jsonMatch = aiResponse.match(/\\{[\\s\\S]*\\}/);\n  aiResult = JSON.parse(jsonMatch[0]);\n} catch (e) {\n  // Fallback data if JSON formatting breaks\n  aiResult = {\n    score: 0,\n    classification: 'average',\n    summary: 'Could not parse AI response',\n    strengths: 'N/A',\n    concerns: 'N/A',\n    interview_recommended: false\n  };\n}\n\n// 3. Return standard n8n object structure\nreturn {\n  json: {\n    candidateId: 'CAND-' + Date.now(),\n    name: prevData.name,\n    email: prevData.email,\n    role: prevData.role,\n    resumeUrl: prevData.resumeUrl,\n    score: aiResult.score || 0,\n    classification: aiResult.classification || 'average',\n    summary: aiResult.summary || 'N/A',\n    strengths: aiResult.strengths || 'N/A',\n    concerns: aiResult.concerns || 'N/A',\n    interviewRecommended: String(aiResult.interview_recommended) === 'true', // Ensure boolean matching\n    emailStatus: 'pending',\n    calendarCreated: false,\n    processedAt: new Date().toISOString()\n  }\n};"
      },
