        "responses": {
          "values": [
            {
              "role": "system",
              "content": "=You are an expert hiring manager AI. Evaluate the provided resume for the role of {{ $json.text }}.\n \nReturn ONLY a valid JSON object with these exact fields:\n{\n  \"score\": <number 0-100>,\n  \"classification\": \"<strong|average|weak>\",\n  \"summary\": \"<2-3 sentence summary of the candidate>\",\n  \"strengths\": \"<key strengths as comma-separated list>\",\n  \"concerns\": \"<key concerns or gaps as comma-separated list>\",\n  \"interview_recommended\": <true|false>\n}\n \nEvaluation criteria depends on role:\n- For Software Engineer: focus on technical skills, programming languages, projects, GitHub activity, problem-solving experience\n- For Business Development Manager: focus on sales experience, revenue targets met, relationship building, industry knowledge, communication skills\n \nBe honest and objective. Score 70+ = strong, 40-69 = average, below 40 = weak."
            },
            {
              "content": "=Candidate Name: {{ $('Has Applications?').item.json.name }}\nRole Applied For: {{ $('Has Applications?').item.json.role }}\n \nRESUME CONTENT:\n{{ $json.text }}"
            }
          ]
        },
        "builtInTools": {},
        "options": {
          "store": false
        }
      },
